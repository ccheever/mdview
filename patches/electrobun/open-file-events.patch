+    - (void)handleOpenDocumentsEvent:(NSAppleEventDescriptor *)event withReplyEvent:(NSAppleEventDescriptor *)replyEvent {
+        NSAppleEventDescriptor *directObject = [event paramDescriptorForKeyword:keyDirectObject];
+        NSInteger count = [directObject numberOfItems];
+
+        // Collect all file paths from the Apple Event
+        NSMutableArray<NSString *> *paths = [NSMutableArray array];
+
+        if (count == 0) {
+            // Single item (not a list)
+            NSString *urlString = [directObject stringValue];
+            if (urlString) {
+                NSURL *url = [NSURL URLWithString:urlString];
+                NSString *path = url ? [url path] : urlString;
+                if (path) [paths addObject:path];
+            }
+        } else {
+            for (NSInteger i = 1; i <= count; i++) {
+                NSAppleEventDescriptor *item = [directObject descriptorAtIndex:i];
+                NSString *urlString = [item stringValue];
+                if (urlString) {
+                    NSURL *url = [NSURL URLWithString:urlString];
+                    NSString *path = url ? [url path] : urlString;
+                    if (path) [paths addObject:path];
+                }
+            }
+        }
