+const ELECTROBUN_STARTUP_OPEN_FILES_ENV = "ELECTROBUN_STARTUP_OPEN_FILES";
+const emittedStartupOpenFiles = new Set<string>();
+
+function emitOpenFileEvent(path: string) {
+	const normalizedPath = resolve(path);
+	if (emittedStartupOpenFiles.has(normalizedPath)) {
+		return;
+	}
+
+	emittedStartupOpenFiles.add(normalizedPath);
+	const handler = electrobunEventEmitter.events.app.openFile;
+	const event = handler({ path: normalizedPath });
+	electrobunEventEmitter.emitEvent(event);
+}
+
+function getStartupOpenFiles(): string[] {
+	const raw = process.env[ELECTROBUN_STARTUP_OPEN_FILES_ENV];
+
+	if (raw) {
+		try {
+			const parsed = JSON.parse(raw);
+			if (Array.isArray(parsed)) {
+				return [...new Set(parsed)]
+					.map((candidate) => String(candidate))
+					.map((candidate) => candidate.trim())
+					.filter((candidate): candidate is string => candidate.length > 0)
+					.map((candidate) => resolve(candidate));
+			}
+		} catch {
+			// Ignore malformed env value and fall back to runtime args.
+		}
+	}
+
+	const runtimeArgs = process.argv.slice(2); // skip bun binary and script path
+	return [...new Set(runtimeArgs)]
+		.map((candidate) => String(candidate))
+		.map((candidate) => candidate.trim())
+		.filter((candidate): candidate is string => candidate.length > 0)
+		.filter((candidate) => !candidate.startsWith("-"))
+		.map((candidate) => resolve(candidate))
+		.filter((candidate) => existsSync(candidate));
+}
+
+export const dispatchStartupOpenFileEvents = (): void => {
+	const openPaths = getStartupOpenFiles();
+
+	if (openPaths.length === 0) {
+		return;
+	}
+
+	queueMicrotask(() => {
+		for (const path of openPaths) {
+			emitOpenFileEvent(path);
+		}
+	});
+};
