+        // Dispatch the callback asynchronously on a background queue
+        // so we don't block the Apple Event handling, and the JSCallback
+        // threadsafe invocation has a chance to be processed by bun's Worker.
+        for (NSString *path in paths) {
+            NSString *pathCopy = [path copy];
+            // Write the file path to a signal file that the JS side watches.
+            // The JSCallback mechanism doesn't work reliably when called from
+            // within the NSApplication event loop, so we use file-based IPC.
+            NSString *tmpDir = NSTemporaryDirectory();
+            NSString *signalFile = [tmpDir stringByAppendingPathComponent:
+                [NSString stringWithFormat:@"electrobun-open-file-%d", getpid()]];
+
+            NSFileHandle *fh = [NSFileHandle fileHandleForWritingAtPath:signalFile];
+            if (fh) {
+                [fh seekToEndOfFile];
+                NSString *line = [NSString stringWithFormat:@"%@\n", pathCopy];
+                [fh writeData:[line dataUsingEncoding:NSUTF8StringEncoding]];
+                [fh closeFile];
+            } else {
+                NSString *line = [NSString stringWithFormat:@"%@\n", pathCopy];
+                [line writeToFile:signalFile atomically:YES encoding:NSUTF8StringEncoding error:nil];
+            }
+        }
+    }
